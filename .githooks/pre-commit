#!/usr/bin/env bash
# Pre-commit hook: block model files, secrets, and large binaries
set -euo pipefail

BLOCKED_PATTERNS=(
    "*.safetensors"
    "*.bin"
    "*.gguf"
    "*.env"
    ".mcp.json"
    "qwen3-asr-0.6b/*"
    "qwen3-asr-1.7b/*"
)

staged_files=$(git diff --cached --name-only --diff-filter=ACM)

for file in $staged_files; do
    for pattern in "${BLOCKED_PATTERNS[@]}"; do
        if [[ "$file" == $pattern ]]; then
            echo "BLOCKED: '$file' matches forbidden pattern '$pattern'"
            echo "These files should not be committed (models, secrets, large binaries)."
            exit 1
        fi
    done

    # Block files larger than 10MB
    if [[ -f "$file" ]]; then
        size=$(wc -c < "$file" 2>/dev/null || echo 0)
        if (( size > 10485760 )); then
            echo "BLOCKED: '$file' is $(( size / 1048576 ))MB (max 10MB)"
            exit 1
        fi
    fi
done
